<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/app_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:paddingTop="48dp">

        <TextView
            style="@style/TitleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BiciPUCP"
            android:layout_marginTop="16dp" />

        <TextView
            style="@style/TitleMedium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Regístrate para acceder"
            android:layout_marginTop="4dp"
            android:textAlignment="center" />

        <!-- Tarjeta con campos -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:cardBackgroundColor="@color/app_bg"
            app:strokeWidth="0dp"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Campo Correo PUCP -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:hint="Correo PUCP"
                    app:boxStrokeColor="@color/blue_light"
                    app:hintTextColor="@color/blue_medium"
                    app:startIconDrawable="@drawable/ic_mail"
                    app:startIconTint="@color/blue_light">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/blue_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:hint="Contraseña"
                    app:boxStrokeColor="@color/blue_light"
                    app:hintTextColor="@color/blue_medium"
                    app:endIconMode="password_toggle"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/blue_light">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/blue_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo Código PUCP (8 dígitos) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCodigo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:hint="Código PUCP (8 dígitos)"
                    app:boxStrokeColor="@color/blue_light"
                    app:startIconTint="@color/blue_light">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputCodigo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="8"
                        android:textColor="@color/blue_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo PIN del candado (4 dígitos) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:hint="PIN del candado (4 dígitos)"
                    app:boxStrokeColor="@color/blue_light"
                    app:startIconTint="@color/blue_light">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputPin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberPassword"
                        android:maxLength="4"
                        android:textColor="@color/blue_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ProgressBar (oculto inicialmente) -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

                <!-- Botón Registrar -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    style="@style/Widget.MyApp.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="28dp"
                    android:text="Registrar"
                    android:textAllCaps="true"
                    app:cornerRadius="28dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Enlace a Login -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                style="@style/BodyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Ya tienes cuenta?" />

            <TextView
                android:id="@+id/btnOpenLogin"
                style="@style/LinkText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="Iniciar sesión" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>